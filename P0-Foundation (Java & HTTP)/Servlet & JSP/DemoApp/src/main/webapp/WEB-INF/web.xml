<?xml version="1.0" encoding="UTF-8"?>
<web-app id="WebApp_ID" version="2.4" xmlns="http://java.sun.com/xml/ns/j2ee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee http://java.sun.com/xml/ns/j2ee/web-app_2_4.xsd">
	
<servlet> <!-- In a file there can be multiple servlet -->
	<servlet-name>adder</servlet-name>
	<servlet-class>com.shivamjha2712.AddServlet</servlet-class> <!-- This is supposed to be given as a fully qualified name also having the package name as well to work it out -->
</servlet>

<servlet-mapping>
	<servlet-name>adder</servlet-name>
	<url-pattern>/add</url-pattern>
</servlet-mapping>

<servlet> <!-- In a file there can be multiple servlet -->
	<servlet-name>squarer</servlet-name>
	<servlet-class>com.shivamjha2712.SqServlet</servlet-class> <!-- This is supposed to be given as a fully qualified name also having the package name as well to work it out -->
</servlet>

<servlet-mapping>
	<servlet-name>squarer</servlet-name>
	<url-pattern>/sq</url-pattern>
</servlet-mapping>

	
</web-app>
